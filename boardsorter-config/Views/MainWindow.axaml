<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:BoardsorterConfig.ViewModels"
        xmlns:models="using:BoardsorterConfig.Models"
        mc:Ignorable="d" d:DesignWidth="950" d:DesignHeight="650"
        x:Class="BoardsorterConfig.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="950" Height="650"
        Title="Boardsorter 配置"
        FontFamily="Source Han Sans SC,思源黑体,Microsoft YaHei">
    <Window.Styles>
        <Style Selector="DataGrid">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        </Style>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style Selector="TextBlock.desc">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontSize" Value="11" />
        </Style>
    </Window.Styles>
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SystemControlBackgroundAltLowBrush}" Padding="8,4">
            <Grid ColumnDefinitions="*,*">
                <TextBlock Grid.Column="0" Text="{Binding ConnectionStatus}" />
                <TextBlock Grid.Column="1" Text="{Binding LastActivity}" HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListBox Grid.Column="0" x:Name="NavList" Background="{DynamicResource SystemControlBackgroundAltLowBrush}" SelectedIndex="0">
                <ListBoxItem Content="监控配置" />
                <ListBoxItem Content="AI 配置" />
                <ListBoxItem Content="启动项" />
                <ListBoxItem Content="词条库" />
                <ListBoxItem Content="文件元数据" />
                <ListBoxItem Content="日志" />
                <ListBoxItem Content="外观" />
                <ListBoxItem Content="通知" />
            </ListBox>

            <Grid Grid.Column="1" x:Name="ContentArea" Margin="6">
                <!-- Page0: 监控配置 -->
                <ScrollViewer x:Name="Page0" IsVisible="True">
                    <StackPanel Spacing="8" Margin="8">
                        <TextBlock Text="监控目录" />
                        <TextBox Text="{Binding WatchDir}" Watermark="例如 D:\Boards\Inbox" />
                        <TextBlock Text="归档目录" />
                        <TextBox Text="{Binding ArchiveDir}" Watermark="例如 D:\Boards\Archive" />
                        <TextBlock Text="学科类目 (逗号分隔)" />
                        <TextBox Text="{Binding SubjectsText}" Watermark="数学, 物理, 化学" />
                        <Button Content="保存" Command="{Binding SaveConfigCommand}" HorizontalAlignment="Left" Margin="0,8,0,0" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Page1: AI 配置 -->
                <ScrollViewer x:Name="Page1" IsVisible="False">
                    <StackPanel Spacing="8" Margin="8">
                        <TextBlock Text="端点 (Endpoint)" />
                        <TextBox Text="{Binding AiEndpoint}" Watermark="https://api.openai.com/v1" />
                        <TextBlock Text="API Key" />
                        <TextBox Text="{Binding AiApiKey}" PasswordChar="*" Watermark="sk-..." />
                        <TextBlock Text="模型" />
                        <TextBox Text="{Binding AiModel}" Watermark="gpt-4o-mini" />
                        <TextBlock Text="推理等级" />
                        <ComboBox ItemsSource="{Binding AiReasoningLevels}"
                                  SelectedItem="{Binding AiReasoningLevel}"
                                  HorizontalAlignment="Stretch" />
                        <TextBlock Text="提示词" />
                        <TextBox Text="{Binding AiPrompt}" AcceptsReturn="True" Height="160"
                                 Watermark="请根据以下文件名判断学科..." />
                        <Button Content="保存" Command="{Binding SaveConfigCommand}" HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Page2: 启动项 -->
                <ScrollViewer x:Name="Page2" IsVisible="False">
                    <StackPanel Spacing="10" Margin="8">
                        <TextBlock Text="开机自启动" FontWeight="Bold" />
                        <CheckBox Content="启用任务管理器启动项 (HKCU\...\Run)"
                                  IsChecked="{Binding AutoStart}" />
                        <TextBlock Classes="desc" Text="任务管理器 → 启动 Tab 中可以看到本项，可在那里直接禁用/启用" />

                        <Separator Margin="0,10,0,0" />
                        <TextBlock Text="开始菜单快捷方式" FontWeight="Bold" Margin="0,10,0,0" />
                        <CheckBox Content="在开始菜单创建快捷方式"
                                  IsChecked="{Binding StartMenuShortcut}" />
                        <TextBlock Classes="desc" Text="快捷方式位于: %APPDATA%\Microsoft\Windows\Start Menu\Programs\boardsorter.lnk" />

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                            <Button Content="创建开始菜单快捷方式" Command="{Binding CreateStartMenuCommand}" />
                            <Button Content="移除开始菜单快捷方式" Command="{Binding RemoveStartMenuCommand}" />
                        </StackPanel>

                        <Separator Margin="0,10,0,0" />
                        <TextBlock Text="IPC 端口" FontWeight="Bold" Margin="0,10,0,0" />
                        <TextBox Text="{Binding IpcPort}" />
                        <TextBlock Classes="desc" Text="0 表示使用随机端口 (59812-59820)，写回 data/ipc.json" />

                        <Button Content="保存" Command="{Binding SaveConfigCommand}"
                                HorizontalAlignment="Left" Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Page3: 词条库（精确高度布局，避免右侧溢出） -->
                <Grid x:Name="Page3" Margin="8" IsVisible="False"
                      RowDefinitions="Auto,*,Auto,Auto,Auto,*">
                    <StackPanel Grid.Row="0" Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding TermQuery}" Width="180" Watermark="搜索词条" />
                            <ComboBox ItemsSource="{Binding SubjectOptions}" 
                                      SelectedItem="{Binding SubjectFilter}"
                                      Width="120" />
                            <Button Content="刷新" Command="{Binding RefreshTermsCommand}" />
                            <CheckBox Content="自动刷新" IsChecked="{Binding AutoRefresh}" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock Text="词条列表（点击词条查看关联文件）" FontWeight="Bold" Margin="0,4,0,2" />
                    </StackPanel>

                    <!-- 词条列表 -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Terms}" 
                              SelectedItem="{Binding SelectedTerm}"
                              AutoGenerateColumns="False"
                              MaxHeight="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="词条" Binding="{Binding Term}" Width="*" />
                            <DataGridTextColumn Header="学科" Binding="{Binding Subject}" Width="100" />
                            <DataGridTextColumn Header="次数" Binding="{Binding Count}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Text="关联文件（双击行打开文件）" FontWeight="Bold" Margin="0,8,0,4" />

                    <!-- 选中词条关联的文件 -->
                    <DataGrid Grid.Row="3" ItemsSource="{Binding TermFiles}" AutoGenerateColumns="False"
                              MaxHeight="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="路径" Binding="{Binding Path}" Width="*" />
                            <DataGridTextColumn Header="学科" Binding="{Binding Subject}" Width="80" />
                            <DataGridTextColumn Header="大小" Binding="{Binding Size}" Width="70" />
                            <DataGridTemplateColumn Header="操作" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="models:FileMeta">
                                        <Button Content="打开"
                                                Command="{Binding $parent[DataGrid].DataContext.OpenFileCommand}"
                                                CommandParameter="{Binding Path}"
                                                x:CompileBindings="False" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Separator Grid.Row="4" Margin="0,6" />

                    <!-- 手动规则（折叠展开） -->
                    <Expander Grid.Row="5" Header="手动规则（与词条功能类似，可手动配置模式匹配）"
                              IsExpanded="False">
                        <Grid RowDefinitions="*,Auto" Height="160">
                            <DataGrid Grid.Row="0" ItemsSource="{Binding Rules}" 
                                      SelectedItem="{Binding SelectedRule}" 
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="模式" Binding="{Binding Pattern}" Width="*" />
                                    <DataGridTextColumn Header="学科" Binding="{Binding Subject}" Width="100" />
                                    <DataGridTextColumn Header="优先级" Binding="{Binding Priority}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                <Button Content="新增规则" Command="{Binding AddRuleCommand}" />
                                <Button Content="删除选中" Command="{Binding RemoveSelectedRuleCommand}" />
                                <Button Content="保存" Command="{Binding SaveConfigCommand}" />
                            </StackPanel>
                        </Grid>
                    </Expander>
                </Grid>

                <!-- Page4: 文件元数据 -->
                <DockPanel x:Name="Page4" Margin="8" IsVisible="False">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <Button Content="刷新" Command="{Binding RefreshFilesCommand}" />
                        <ComboBox ItemsSource="{Binding SubjectOptions}" 
                                  SelectedItem="{Binding FileSubjectFilter}"
                                  Width="120" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding Files}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="路径" Binding="{Binding Path}" Width="*" />
                            <DataGridTextColumn Header="学科" Binding="{Binding Subject}" Width="100" />
                            <DataGridTextColumn Header="大小" Binding="{Binding Size}" Width="80" />
                            <DataGridTextColumn Header="修改时间" Binding="{Binding ModifiedAt}" Width="140" />
                            <DataGridTemplateColumn Header="操作" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate DataType="models:FileMeta">
                                        <Button Content="打开"
                                                Command="{Binding $parent[DataGrid].DataContext.OpenFileCommand}"
                                                CommandParameter="{Binding Path}"
                                                x:CompileBindings="False" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <!-- Page5: 日志 -->
                <DockPanel x:Name="Page5" Margin="8" IsVisible="False">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <Button Content="刷新" Command="{Binding RefreshLogsCommand}" />
                        <CheckBox Content="自动刷新" IsChecked="{Binding AutoRefresh}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Logs}">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="models:LogEntry">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Time}" Width="140" />
                                    <TextBlock Text="{Binding Level}" Width="60" FontWeight="Bold" />
                                    <TextBlock Text="{Binding Message}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>

                <!-- Page6: 外观 -->
                <ScrollViewer x:Name="Page6" IsVisible="False">
                    <StackPanel Spacing="10" Margin="8">
                        <TextBlock Text="外观" Classes="header" />
                        <CheckBox Content="深色模式" IsChecked="{Binding DarkMode}" />
                        <TextBlock Classes="desc" Text="切换后立即生效，设置保存在 config.ini 的 [UI配置] 节中" />
                        <Button Content="保存设置" Command="{Binding SaveConfigCommand}" HorizontalAlignment="Left" Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Page7: 通知 -->
                <ScrollViewer x:Name="Page7" IsVisible="False">
                    <StackPanel Spacing="10" Margin="8">
                        <TextBlock Text="文件分类通知" Classes="header" />
                        <CheckBox Content="启用文件分类通知" IsChecked="{Binding NotifyEnabled}" />
                        <TextBlock Classes="desc" Text="文件被分类后，通过 Windows 原生 Toast 通知推送。" />
                        <Button Content="保存设置" Command="{Binding SaveConfigCommand}" HorizontalAlignment="Left" Margin="0,10,0,0" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</Window>